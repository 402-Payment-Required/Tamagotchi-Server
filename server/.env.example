# server/.env.example
# 실제 값은 이 파일을 복사해 .env로 저장하고 채워 넣기 (.env는 커밋 금지)
#
#   cp server/.env.example server/.env
#   # .env 편집

# Anthropic Claude API 키 (필수, Haiku 4.5 사용)
# https://console.anthropic.com/settings/keys 에서 발급
ANTHROPIC_API_KEY=

# (선택) 콘솔 출력 인코딩 — Windows 콘솔에서 한글 깨짐 방지
# PYTHONIOENCODING=utf-8

# (선택) uvicorn 로그 레벨 (debug|info|warning|error). 기본 info.
# UVICORN_LOG_LEVEL=info
